<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
{{baseCSS}}
.receipt-wrap { max-width: 420px; margin: 0 auto; border: 2px solid #0f172a; border-radius: 8px; padding: 28px; }
.receipt-header { text-align: center; border-bottom: 1px dashed #cbd5e1; padding-bottom: 16px; margin-bottom: 16px; }
.receipt-row { display: flex; justify-content: space-between; margin: 6px 0; font-size: 12px; }
.receipt-row.big { font-size: 16px; font-weight: 700; margin-top: 10px; border-top: 1px solid #1e293b; padding-top: 10px; }
.receipt-footer { text-align: center; margin-top: 20px; font-size: 11px; color: #64748b; border-top: 1px dashed #cbd5e1; padding-top: 12px; }
</style>
</head>
<body>
<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;padding:20px;">
  <div class="receipt-wrap">
    <div class="receipt-header">
      <div style="font-size:22px;font-weight:800;letter-spacing:-0.5px;">Stitch't</div>
      <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:1px;">Official Receipt</div>
      <div style="margin-top:8px;font-size:13px;font-weight:700;color:#3b82f6;">{{receiptNumber}}</div>
    </div>

    <div class="receipt-row"><span style="color:#64748b;">Date</span><strong>{{formatDate paymentDate}}</strong></div>
    <div class="receipt-row"><span style="color:#64748b;">Customer</span><strong>{{customer.displayName}}</strong></div>
    <div class="receipt-row"><span style="color:#64748b;">Reference</span><strong>{{reference}}</strong></div>
    <div class="receipt-row"><span style="color:#64748b;">Payment Method</span><strong>{{method}}</strong></div>
    {{#if gatewayRef}}<div class="receipt-row"><span style="color:#64748b;">Gateway Ref</span><span style="font-size:11px;color:#64748b;">{{gatewayRef}}</span></div>{{/if}}

    <div class="receipt-row big">
      <span>AMOUNT RECEIVED</span>
      <span>{{currencyCode}} {{formatMoney amount}}</span>
    </div>

    {{#if isDeposit}}<div style="text-align:center;margin:10px 0;font-size:11px;color:#f59e0b;font-weight:600;">DEPOSIT PAYMENT</div>{{/if}}
    {{#if allocations}}
    <div style="margin-top:12px;font-size:11px;color:#64748b;">
      <div style="font-weight:600;margin-bottom:4px;">Applied to:</div>
      {{#each allocations}}<div style="display:flex;justify-content:space-between;"><span>Invoice {{invoice.invoiceNumber}}</span><span>{{../../currencyCode}} {{formatMoney amount}}</span></div>{{/each}}
    </div>
    {{/if}}

    {{#if qrDataUri}}<div style="text-align:center;margin-top:16px;"><img src="{{qrDataUri}}" style="width:80px;height:80px;"><div style="font-size:9px;color:#94a3b8;margin-top:2px;">Scan to verify</div></div>{{/if}}

    <div class="receipt-footer">
      {{company.name}} · {{company.address}}<br>
      {{company.phone}} · {{company.email}}<br><br>
      <em>Thank you for your payment!</em>
    </div>
  </div>
</div>
</body>
</html>
