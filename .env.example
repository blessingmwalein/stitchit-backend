# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://stitchit:CHANGE_ME@localhost:5432/stitchit_erp"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_32_CHARS_MIN"
JWT_REFRESH_SECRET="CHANGE_ME_32_CHARS_MIN_DIFFERENT"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="stitchit"
MINIO_SECRET_KEY="CHANGE_ME"
MINIO_BUCKET_FILES="stitchit-files"
MINIO_BUCKET_DOCUMENTS="stitchit-documents"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PREFIX="api/v1"
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# ─── Company seed ─────────────────────────────────────────────────────────────
DEFAULT_COMPANY_ID=""
SEED_ADMIN_EMAIL="admin@stitchit.co.zw"
SEED_ADMIN_PASSWORD="CHANGE_ME"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_CHANGE_ME"
STRIPE_WEBHOOK_SECRET="whsec_CHANGE_ME"

# ─── Paynow Zimbabwe ──────────────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID="CHANGE_ME"
PAYNOW_INTEGRATION_KEY="CHANGE_ME"
PAYNOW_RETURN_URL="https://yourdomain.com/payment/return"
PAYNOW_RESULT_URL="https://yourdomain.com/api/v1/payments-gateway/paynow/webhook"

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="CHANGE_ME"
WHATSAPP_ACCESS_TOKEN="CHANGE_ME"
WHATSAPP_VERIFY_TOKEN="CHANGE_ME"
WHATSAPP_BUSINESS_ACCOUNT_ID="CHANGE_ME"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="CHANGE_ME@gmail.com"
SMTP_PASS="CHANGE_ME"
SMTP_FROM="Stitch't <noreply@stitchit.co.zw>"

# ─── Puppeteer PDF ────────────────────────────────────────────────────────────
CHROMIUM_PATH=""
PDF_CONCURRENCY=2
